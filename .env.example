# Groq API configuration
#
# Copy this file and rename the copy to:
# .env
#
# Never place a real API key in this example file.

GROQ_API_KEY=replace_with_your_groq_api_key

# Model used to generate daily plans.
# This value can be replaced with another supported Groq model.
GROQ_MODEL=llama-3.1-8b-instant